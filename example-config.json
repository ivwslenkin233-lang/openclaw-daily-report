{
  "date": "",
  "maxArticles": 30,
  "maxPerBlog": 3,
  "includeBlogs": [],
  "excludeBlogs": [],
  "blacklistKeywords": [],
  
  "dateRange": {
    "daysBack": 3
  },

  "sourceWeights": {
    "Stratechery": 1.5,
    "Quanta Magazine": 1.4,
    "MIT Technology Review": 1.3,
    "The Economist": 1.3,
    "Financial Times": 1.3,
    "TechCrunch": 1.2,
    "WIRED": 1.2,
    "Ars Technica": 1.2,
    "Bloomberg Technology": 1.2,
    "ScienceDaily": 1.1,
    "Nature": 1.2,
    "Lenny's Newsletter": 1.3,
    "Andrew Chen": 1.2,
    "First Round Review": 1.2,
    "Hacker News": 0.8,
    "Product Hunt": 0.5,
    "36氪": 0.3,
    "Bits of Baseball": 0.4,
    "Paul Graham": 0.7
  },

  "topicWeights": {
    "enabled": false
  },

  "valueScoring": {
    "enabled": true,
    "weights": {
      "sourceWeight": 0.40,
      "topicMatch": 0.0,
      "titleLength": 0.20,
      "hasNumber": 0.10,
      "hasQuestion": -0.10,
      "clickbaitPenalty": -0.20
    }
  },

  "output": {
    "format": "markdown",
    "path": "memory/daily-reports/{date}.md",
    "includeStats": true,
    "groupBy": "blog",
    "sortBy": "valueScore"
  }
}