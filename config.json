{
  "date": "",
  "maxArticles": 50,
  "maxPerBlog": 3,
  "includeBlogs": [],
  "excludeBlogs": [],
  "blacklistKeywords": [],
  
  "dateRange": {
    "daysBack": 3
  },

  "sourceWeights": {
    "Stratechery": 1.5,
    "Quanta Magazine": 1.4,
    "MIT Technology Review": 1.3,
    "The Economist": 1.3,
    "Financial Times": 1.3,
    "TechCrunch": 1.2,
    "WIRED": 1.2,
    "Ars Technica": 1.2,
    "Bloomberg Technology": 1.2,
    "ScienceDaily": 1.1,
    "Nature": 1.2,
    "Lenny's Newsletter": 1.3,
    "Andrew Chen": 1.2,
    "First Round Review": 1.2,
    "Hacker News": 0.8,
    "Product Hunt": 0.5,
    "36氪": 0.3,
    "bitsOfBaseball": 0.4,
    "Paul Graham": 0.7
  },

  "topicWeights": {
    "enabled": true,
    "数学": {
      "keywords": ["数学", "算法", "theorem", "proof", "代数", "几何", "topology", "number theory", "证明", "方程", "数学界"],
      "boost": 0.25
    },
    "AI": {
      "keywords": ["AI", "人工智能", "机器学习", "深度学习", "神经网络", "LLM", "GPT", "Claude", "模型", "推理", "大模型", "transformer", "AI 系统"],
      "boost": 0.3
    },
    "产品经理": {
      "keywords": ["产品", "PM", "product manager", "user experience", "UX", "growth", "metric", "roadmap", "go-to-market", "产品策略", "用户增长"],
      "boost": 0.25
    }
  },

  "valueScoring": {
    "enabled": true,
    "weights": {
      "sourceWeight": 0.35,
      "topicMatch": 0.25,
      "titleLength": 0.15,
      "hasNumber": 0.10,
      "hasQuestion": -0.10,
      "clickbaitPenalty": -0.25
    }
  },

  "output": {
    "format": "markdown",
    "path": "memory/daily-reports/{date}.md",
    "includeStats": true,
    "groupBy": "blog",
    "sortBy": "valueScore"
  }
}